@{
    ViewData["Title"] = "Turno Asignado";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }
        
        .success-container {
            max-width: 550px;
            width: 100%;
            background: white;
            border-radius: 20px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.3);
            overflow: hidden;
            text-align: center;
        }
        
        .success-header {
            background: linear-gradient(135deg, #0a2463 0%, #1e3c72 100%);
            color: white;
            padding: 30px;
        }
        
        .success-icon {
            font-size: 70px;
            background: #28a745;
            width: 100px;
            height: 100px;
            line-height: 100px;
            border-radius: 50%;
            margin: 0 auto 20px;
            display: inline-block;
        }
        
        .ticket-display {
            background: #f8f9fa;
            margin: 20px;
            padding: 30px;
            border-radius: 15px;
            border: 2px dashed #0a2463;
        }
        
        .ticket-label {
            font-size: 14px;
            color: #666;
            letter-spacing: 2px;
        }
        
        .ticket-number {
            font-size: 48px;
            font-weight: bold;
            color: #0a2463;
            margin: 15px 0;
            font-family: monospace;
        }
        
        .info-row {
            display: flex;
            justify-content: space-between;
            padding: 12px;
            background: white;
            border-radius: 10px;
            margin: 10px 0;
        }
        
        .btn-primary {
            display: inline-block;
            width: 80%;
            padding: 14px;
            background: linear-gradient(135deg, #0a2463 0%, #1e3c72 100%);
            color: white;
            border: none;
            border-radius: 10px;
            font-size: 16px;
            font-weight: bold;
            text-decoration: none;
            text-align: center;
            margin: 20px 0;
        }
        
        .btn-primary:hover {
            background: linear-gradient(135deg, #1e3c72 0%, #0a2463 100%);
        }
        
        .advertencia {
            background: #fff3cd;
            padding: 12px;
            border-radius: 8px;
            margin: 15px;
            font-size: 13px;
            color: #856404;
        }
    </style>
</head>
<body>
    <div class="success-container">
        <div class="success-header">
            <div class="success-icon">✅</div>
            <h2>¡TURNO ASIGNADO!</h2>
            <p>Por favor espere a ser llamado</p>
        </div>
        
        <div class="ticket-display">
            <div class="ticket-label">SU NÚMERO DE TURNO</div>
            <div class="ticket-number">@ViewBag.NumeroTicket</div>
            <hr>
            <div class="info-row">
                <span>📅 Fecha:</span>
                <strong>@DateTime.Now.ToString("dd/MM/yyyy")</strong>
            </div>
            <div class="info-row">
                <span>⏰ Hora:</span>
                <strong>@DateTime.Now.ToString("hh:mm:ss tt")</strong>
            </div>
            <div class="info-row">
                <span>📊 Estado:</span>
                <strong style="color:#ffc107;">En Espera</strong>
            </div>
        </div>
        
        <div class="advertencia">
            ⚠️ Manténgase en la sala de espera. Su turno será anunciado en las pantallas.
        </div>
        
        <a href="/Turno/TomarTurno" class="btn-primary">🎫 SACAR OTRO TURNO</a>
    </div>
</body>
</html>